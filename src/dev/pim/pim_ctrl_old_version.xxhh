namespace gem5
{

namespace memory {
class PIMSim;
}


  
class PIMCtrl : public BasicPioDevice
{
  private:
    memory::PIMSim *pimMem;

    uint64_t cmdReg;
    uint64_t dimReg;
    uint64_t input0RowReg;
    uint64_t input1RowReg;
    uint64_t resultRowReg;
    uint64_t bankReg;

    uint64_t batchReg;
    uint64_t inputDimReg;
    uint64_t outputDimReg;

    uint64_t statusReg;
    uint64_t lastCyclesReg;

    Tick launchCommand();

    uint64_t readRegister(Addr offset) const;
    void writeRegister(Addr offset, uint64_t value, Tick &extra_delay);

  static constexpr Addr PIM_REG_SIZE = 0x1000;


/***************************************************************************************** */



